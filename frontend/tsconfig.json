{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@public/*": [
        "./public/*"
      ],
      "@api/*": [
        "./src/api/*"
      ],
      "@components/svgr/*": [
        "./src/components/atoms/svgr/*"
      ],
      "@components/form": [
        "./src/components/atoms/form"
      ],
      "@components/form/*": [
        "./src/components/atoms/form/*"
      ],
      "@components/templates/card": [
        "./src/components/molecules/card"
      ],
      "@components/templates/password-requirements": [
        "./src/components/molecules/password-requirements"
      ],
      "@components/templates/legal-block": [
        "./src/components/atoms/legal-block"
      ],
      "@components/global/liquid-glass-block": [
        "./src/components/atoms/liquid-glass-block"
      ],
      "@components/global/mobile-bottom-menu": [
        "./src/components/organisms/mobile-bottom-menu"
      ],
      "@components/stats": [
        "./src/components/atoms/stats"
      ],
      "@components/tabs/*": [
        "./src/components/molecules/tabs/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@contexts/*": [
        "./src/contexts/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@views/*": [
        "./src/views/*"
      ],
      "@widgets/*": [
        "./src/widgets/*"
      ],
      "@entities/*": [
        "./src/entities/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mjs"
  ],
  "exclude": [
    "node_modules"
  ]
}
