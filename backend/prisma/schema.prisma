generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  firstName String?
  lastName  String?

  phoneNumber String?   @unique @map("phone_number")
  email       String?    @unique
  password    String
  photo       String?
  isVerified  Boolean   @default(false) @map("is_verified")
  role        UserRole  @default(REGULAR)
  gender      Gender?
  dateOfBirth DateTime? @map("date_of_birth")
  contacts    String?
  
  courierRating   Float @default(0) @map("courier_rating")
  customerRating  Float @default(0) @map("customer_rating")

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authoredAds  Ad[] @relation("AdAuthor")
  sentAds      Ad[] @relation("AdSender")
  receivedAds  Ad[] @relation("AdRecipient")
  deliveredAds Ad[] @relation("AdCourier")

  adResponses     AdResponse[]
  chatMembers     ChatMember[]
  messages        Message[]
  reviewsAuthored Review[]     @relation("ReviewAuthor")
  reviewsReceived Review[]     @relation("ReviewTarget")

  mediaPostsAuthored MediaPost[]
  mediaPostLikes     MediaPostLike[]
  mediaPostFavorites MediaPostFavorite[]
  mediaComments      MediaComment[]
  mediaCommentLikes  MediaCommentLike[]

  complaintsAuthored Complaint[] @relation("ComplaintAuthor")
  complaintsReceived Complaint[] @relation("ComplaintTargetUser")

  @@map("users")
}

enum Gender {
  MALE
  FEMALE
}

enum UserRole {
  REGULAR
  ADMIN
}

model Token {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  type      TokenType
  expiresIn DateTime  @map("expires_in")

  @@map("tokens")
}

enum TokenType {
  VERIFICATION
  PASSWORD_RESET
  RECIPIENT_INVITE
}

model Ad {
  id String @id @default(uuid())

  title       String?
  image       String?
  description String?

  status AdStatus @default(ACTIVE)

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  fromCity String? @map("from_city")
  toCity   String? @map("to_city")

  price  Float?
  weight Float?

  isFragile  Boolean? @default(false) @map("is_fragile")
  isDocument Boolean? @default(false) @map("is_document")

  packaging Packaging?

  length Float?
  width  Float?
  height Float?

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId    String  @map("author_id")
  senderId    String? @map("sender_id")
  recipientId String? @map("recipient_id")
  courierId   String? @map("courier_id")

  author    User  @relation("AdAuthor", fields: [authorId], references: [id])
  sender    User? @relation("AdSender", fields: [senderId], references: [id])
  recipient User? @relation("AdRecipient", fields: [recipientId], references: [id])
  courier   User? @relation("AdCourier", fields: [courierId], references: [id])

  responses  AdResponse[]
  chats      Chat[]
  reviews    Review[]
  complaints Complaint[]

  @@map("ads")
}

enum AdStatus {
  ACTIVE
  COMPLETED
}

enum Packaging {
  PACKAGE
  BOX
  ENVELOPE
  FILM
  NO_PACKAGING
  OTHER
}

model AdResponse {
  id        String           @id @default(uuid())
  adId      String           @map("ad_id")
  courierId String           @map("courier_id")
  status    AdResponseStatus @default(PENDING)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  ad        Ad               @relation(fields: [adId], references: [id])
  courier   User             @relation(fields: [courierId], references: [id])
  chat      Chat?

  @@unique([adId, courierId])
  @@map("ad_responses")
}

enum AdResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELED
}

model Chat {
  id         String       @id @default(uuid())
  adId       String?      @map("ad_id")
  responseId String?      @unique @map("response_id")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  ad         Ad?          @relation(fields: [adId], references: [id])
  response   AdResponse?  @relation(fields: [responseId], references: [id])
  members    ChatMember[]
  messages   Message[]

  @@map("chats")
}

model ChatMember {
  chatId     String    @map("chat_id")
  userId     String    @map("user_id")
  role       ChatRole?
  joinedAt   DateTime  @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")
  chat       Chat      @relation(fields: [chatId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@id([chatId, userId])
  @@map("chat_members")
}

enum ChatRole {
  CUSTOMER
  COURIER
}

model Message {
  id        String        @id @default(uuid())
  chatId    String        @map("chat_id")
  senderId  String        @map("sender_id")
  text      String?
  type      MessageType   @default(REGULAR)
  createdAt DateTime      @default(now()) @map("created_at")
  chat      Chat          @relation(fields: [chatId], references: [id])
  sender    User          @relation(fields: [senderId], references: [id])
  files     MessageFile[]

  @@map("messages")
}

enum MessageType {
  REGULAR
  AD_RESPONSE
}

model MessageFile {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  url       String
  mimeType  String   @map("mime_type")
  fileName  String?  @map("file_name")
  size      Int?
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_files")
}

model Review {
  id          String     @id @default(uuid())
  adId        String     @map("ad_id")
  authorId    String     @map("author_id")
  targetId    String     @map("target_id")
  rating      Int
  text        String?
  type        ReviewType
  isAnonymous Boolean    @default(false) @map("is_anonymous")
  createdAt   DateTime   @default(now()) @map("created_at")
  ad          Ad         @relation(fields: [adId], references: [id])
  author      User       @relation("ReviewAuthor", fields: [authorId], references: [id])
  target      User       @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([adId, authorId, targetId, type])
  @@index([targetId, type])
  @@index([targetId, createdAt])
  @@map("reviews")
}

enum ReviewType {
  CUSTOMER_TO_COURIER
  COURIER_TO_CUSTOMER
}

model MediaPost {
  id String @id @default(uuid())

  title String?
  content String?

  image String?

  viewsCount     Int @default(0) @map("views_count")
  likesCount     Int @default(0) @map("likes_count")
  favoritesCount Int @default(0) @map("favorites_count")

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id])

  likes      MediaPostLike[]
  favorites  MediaPostFavorite[]
  comments   MediaComment[]
  complaints Complaint[]

  @@index([authorId, createdAt])
  @@map("media_posts")
}

model MediaPostLike {
  id String @id @default(uuid())

  postId String @map("post_id")
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  post MediaPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("media_post_likes")
}

model MediaPostFavorite {
  id String @id @default(uuid())

  postId String @map("post_id")
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  post MediaPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("media_post_favorites")
}

model MediaComment {
  id String @id @default(uuid())

  postId String @map("post_id")
  userId String @map("user_id")

  parentId String?       @map("parent_id")
  parent   MediaComment? @relation("MediaCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  MediaComment[] @relation("MediaCommentReplies")

  text String?

  likesCount Int @default(0) @map("likes_count")

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post  MediaPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes  MediaCommentLike[]

  @@index([postId, createdAt])
  @@index([parentId, createdAt])
  @@map("media_comments")
}

model MediaCommentLike {
  id String @id @default(uuid())

  commentId String @map("comment_id")
  userId    String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  comment MediaComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId, createdAt])
  @@map("media_comment_likes")
}

enum ComplaintType {
  USER
  AD
  POST
}

model Complaint {
  id   String        @id @default(uuid())
  type ComplaintType
  text String

  authorId String @map("author_id")
  author   User   @relation("ComplaintAuthor", fields: [authorId], references: [id])

  targetUserId String? @map("target_user_id")
  targetUser   User?   @relation("ComplaintTargetUser", fields: [targetUserId], references: [id])

  targetAdId String? @map("target_ad_id")
  targetAd   Ad?     @relation(fields: [targetAdId], references: [id])

  targetPostId String?    @map("target_post_id")
  targetPost   MediaPost? @relation(fields: [targetPostId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("complaints")
}
