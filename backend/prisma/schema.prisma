generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  firstName String?
  lastName  String?

  phoneNumber String?  @unique @map("phone_number")
  email       String   @unique
  password    String
  photo       String?
  isVerified  Boolean  @default(false) @map("is_verified")
  role        UserRole @default(REGULAR)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authoredAds Ad[] @relation("AdAuthor")
  sentAds     Ad[] @relation("AdSender")
  receivedAds Ad[] @relation("AdRecipient")

  @@map("users")
}

enum UserRole {
  REGULAR
  ADMIN
}

model Token {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  type      TokenType
  expiresIn DateTime  @map("expires_in")

  @@map("tokens")
}

enum TokenType {
  VERIFICATION
  PASSWORD_RESET
}

model Ad {
  id String @id @default(uuid())

  title       String
  image       String?
  description String?

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  fromCity String @map("from_city")
  toCity   String @map("to_city")

  price  Float
  weight Float

  isFragile  Boolean @default(false) @map("is_fragile")
  isDocument Boolean @default(false) @map("is_document")

  packaging Packaging

  length Float
  width  Float
  height Float

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId    String  @map("author_id")
  senderId    String? @map("sender_id")
  recipientId String? @map("recipient_id")

  author    User  @relation("AdAuthor", fields: [authorId], references: [id])
  sender    User? @relation("AdSender", fields: [senderId], references: [id])
  recipient User? @relation("AdRecipient", fields: [recipientId], references: [id])

  @@map("ads")
}

enum Packaging {
  PACKAGE
  BOX
  ENVELOPE
  FILM
  NO_PACKAGING
  OTHER
}
