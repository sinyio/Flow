    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
